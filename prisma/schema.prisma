generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Shared Enums
// ============================================================

enum Provider {
  OPENAI
  ANTHROPIC
  GOOGLE
  XAI
}

enum ProjectStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum PromptSource {
  GENERATED
  IMPORTED
}

enum PromptCategory {
  ACCURACY
  RELEVANCE
  CONCISENESS
  TONE
  INSTRUCTION
  EDGE_CASE
  GENERAL
}

enum EvalRunStatus {
  PENDING
  RUNNING
  SCORING
  COMPLETED
  FAILED
}

enum ResponseStatus {
  COMPLETED
  FAILED
  TIMEOUT
  REFUSED
}

// ============================================================
// Shared Infrastructure (Auth, Usage, Events)
// ============================================================

model UserApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     Provider
  encryptedKey String
  keyHint      String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
}

model UsageLog {
  id               String         @id @default(cuid())
  userId           String
  modelResponseId  String?
  provider         Provider
  model            String
  inputTokens      Int
  outputTokens     Int
  estimatedCostUsd Decimal        @db.Decimal(10, 8)
  createdAt        DateTime       @default(now())
  modelResponse    ModelResponse? @relation("ModelResponseUsageLogs", fields: [modelResponseId], references: [id])
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  eventType String
  payload   Json
  createdAt DateTime @default(now())

  @@index([userId, eventType])
  @@index([sessionId])
}

// ============================================================
// Eval Platform Models
// ============================================================

model EvalProject {
  id             String        @id @default(cuid())
  userId         String
  name           String
  useCaseProfile Json?
  status         ProjectStatus @default(DRAFT)
  isArchived     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  promptSets     PromptSet[]
  evalRuns       EvalRun[]

  @@index([userId, isArchived])
}

model PromptSet {
  id               String       @id @default(cuid())
  projectId        String
  source           PromptSource
  generationConfig Json?
  createdAt        DateTime     @default(now())
  project          EvalProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  promptItems      PromptItem[]
  evalRuns         EvalRun[]

  @@index([projectId])
}

model PromptItem {
  id               String          @id @default(cuid())
  promptSetId      String
  category         PromptCategory
  prompt           String
  evaluationFocus  String
  goldStandardHint String?
  orderIndex       Int
  createdAt        DateTime        @default(now())
  promptSet        PromptSet       @relation(fields: [promptSetId], references: [id], onDelete: Cascade)
  modelResponses   ModelResponse[]

  @@index([promptSetId])
}

model EvalRun {
  id               String          @id @default(cuid())
  projectId        String
  promptSetId      String
  targetModels     String[]
  judgeModel       String
  status           EvalRunStatus   @default(PENDING)
  estimatedCostUsd Decimal?        @db.Decimal(10, 8)
  actualCostUsd    Decimal?        @db.Decimal(10, 8)
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  project          EvalProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  promptSet        PromptSet       @relation(fields: [promptSetId], references: [id])
  modelResponses   ModelResponse[]
  evalReport       EvalReport?

  @@index([projectId])
}

model ModelResponse {
  id               String         @id @default(cuid())
  evalRunId        String
  promptItemId     String
  provider         Provider
  model            String
  content          String
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostUsd Decimal?       @db.Decimal(10, 8)
  latencyMs        Int?
  status           ResponseStatus @default(COMPLETED)
  piiMasked        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  evalRun          EvalRun        @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  promptItem       PromptItem     @relation(fields: [promptItemId], references: [id])
  judgeScore       JudgeScore?
  usageLogs        UsageLog[]     @relation("ModelResponseUsageLogs")

  @@index([evalRunId])
  @@index([promptItemId])
}

model JudgeScore {
  id                   String        @id @default(cuid())
  modelResponseId      String        @unique
  judgeModel           String
  accuracy             Int
  relevance            Int
  conciseness          Int
  tone                 Int
  instructionFollowing Int
  reasons              Json
  createdAt            DateTime      @default(now())
  modelResponse        ModelResponse @relation(fields: [modelResponseId], references: [id], onDelete: Cascade)
}

model EvalReport {
  id             String   @id @default(cuid())
  evalRunId      String   @unique
  rankings       Json
  scoreMatrix    Json
  highlights     Json
  costProjection Json
  recommendation String
  createdAt      DateTime @default(now())
  evalRun        EvalRun  @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
}
